{
  "expo": {
    "name": "Tefter",
    "slug": "tefter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tefter",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/maskotavawe.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C63E7"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.denis.tefter",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Tefter koristi galeriju za dodavanje slika pre i posle posla, kao i loga firme.",
          "cameraPermission": "Tefter koristi kameru za fotografisanje slika pre i posle posla."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#1A4FE0",
          "defaultChannel": "job-reminders"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b1e29231-3547-4b69-854f-cd820f069989"
      }
    }
  }
}
