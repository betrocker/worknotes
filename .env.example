# Supabase
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat
EXPO_PUBLIC_RC_GOOGLE_API_KEY=
EXPO_PUBLIC_RC_APPLE_API_KEY=
EXPO_PUBLIC_RC_ENTITLEMENT_ID=pro

# Google Sign-In
# Web Client ID is used by both platforms to obtain the Supabase-compatible id token.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# iOS-only: iOS OAuth Client ID from Google Cloud Console (type: iOS).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# iOS-only: reversed iOS client id (same value as REVERSED_CLIENT_ID from GoogleService-Info.plist,
# e.g. com.googleusercontent.apps.XXXXXXXXXXXX-yyyyyy). Required so the native plugin can
# register the OAuth redirect URL scheme in Info.plist during prebuild.
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
